          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{tsdb_url}}/searchteams.php?t={{team_search}}",
              "host": ["{{tsdb_url}}"],
              "path": ["searchteams.php"],
              "query": [
                {"key": "t", "value": "{{team_search}}"}
