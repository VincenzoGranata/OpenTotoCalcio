    {
      "name": "🏟️ TheSportsDB - Squadre",
      "item": [
        {
          "name": "Cerca squadra per nome",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{tsdb_url}}/searchteams.php?t={{team_search}}",
              "host": ["{{tsdb_url}}"],
              "path": ["searchteams.php"],
              "query": [
                {"key": "t", "value": "{{team_search}}"}
              ]
            },
            "description": "Cerca una squadra per nome. Esempi: AC_Milan, Inter_Milan, Juventus_FC, SSC_Napoli, AS_Roma.\n\nRitorna: idTeam, strTeam, strTeamAlternate, strLeague, strBadge, strBanner, strStadium, intFormedYear, strDescription."
          }
