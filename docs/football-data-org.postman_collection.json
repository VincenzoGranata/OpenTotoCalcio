            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/scorers?limit=10",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "scorers"],
              "query": [
                {"key": "limit", "value": "10"}
              ]
            },
            "description": "Top 10 marcatori. Usa limit per controllare quanti risultati."
          }
        },
        {
          "name": "Serie B",
          "request": {
