  "item": [
    {
      "name": "🏆 Competizioni",
      "item": [
        {
          "name": "Elenco tutte le competizioni",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions",
              "host": ["{{base_url}}"],
              "path": ["competitions"]
            },
            "description": "Lista di tutte le competizioni disponibili (senza token mostra tutte, con token mostra solo quelle del tuo tier)"
          }
        },
        {
          "name": "Dettaglio Serie A",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}"]
            },
            "description": "Info complete sulla Serie A: nome, stagione corrente, stagioni passate, logo"
          }
        },
        {
          "name": "Classifica Serie A (TOTAL)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/standings",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "standings"]
            },
            "description": "Classifica completa Serie A (TOTAL + HOME + AWAY). Usa il parametro ?season=2025 per una stagione specifica."
          }
        },
        {
          "name": "Classifica Serie A - solo HOME",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/standings?season={{season}}&matchday=15",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "standings"],
              "query": [
                {"key": "season", "value": "{{season}}"},
                {"key": "matchday", "value": "15"}
              ]
            },
            "description": "Classifica dopo una specifica giornata. Utile per vedere la situazione a un dato momento."
          }
        },
        {
          "name": "Squadre Serie A",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/teams",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "teams"]
            },
            "description": "Elenco di tutte le squadre partecipanti alla Serie A con nomi, stemmi, colori, stadi"
          }
        },
        {
          "name": "Partite Serie A (stagione corrente)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/matches",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "matches"]
            },
            "description": "Tutte le partite della stagione corrente di Serie A. Filtra con ?matchday=N per una giornata specifica."
          }
        },
        {
          "name": "Partite Serie A per giornata",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/matches?matchday=1",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "matches"],
              "query": [
                {"key": "matchday", "value": "1"}
              ]
            },
            "description": "Partite di una specifica giornata di Serie A. Cambia matchday da 1 a 38."
          }
        },
        {
          "name": "Partite Serie A per data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/matches?dateFrom=2025-08-15&dateTo=2025-08-31",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "matches"],
              "query": [
                {"key": "dateFrom", "value": "2025-08-15"},
                {"key": "dateTo", "value": "2025-08-31"}
              ]
            },
            "description": "Partite in un intervallo di date. Utile per il calendario mensile."
          }
        },
        {
          "name": "Partite Serie A filtrate per stato",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/competitions/{{league_code}}/matches?status=FINISHED",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{league_code}}", "matches"],
              "query": [
                {"key": "status", "value": "FINISHED"}
              ]
            },
            "description": "Solo partite finite. Altri stati: SCHEDULED, TIMED, IN_PLAY, PAUSED, POSTPONED, CANCELLED, LIVE (pseudo-stato che combina IN_PLAY + PAUSED)"
          }
        },
        {
          "name": "Marcatori Serie A",
